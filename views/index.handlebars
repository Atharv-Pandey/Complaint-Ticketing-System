<div class="user-home">
  <div class="hero-section">
    <div class="hero-content">
      <h1>Welcome, <span class="text-orange">{{user.name}}</span>!</h1>
      <p class="hero-text">Need assistance? Register a new complaint and we'll help resolve your issue.</p>
      <a href="/complaint" class="btn btn-primary btn-lg">
        <i class="fas fa-plus-circle"></i> Register New Complaint
      </a>
    </div>
  </div>

  {{#if complaints.length}}
    <div class="recent-complaints">
      <div class="section-header">
        <h2>Your Recent Complaints</h2>
        <a href="/my-complaints" class="view-all">View All</a>
      </div>
      
      <div class="complaints-grid">
        {{#each complaints}}
          <div class="complaint-card">
            <div class="complaint-header">
              <span class="complaint-id">#{{_id}}</span>
              <span class="badge status-{{toLowerCase status}}">
                {{status}}
              </span>
            </div>
            <p class="complaint-desc">{{truncate desc 100}}</p>
            <div class="complaint-footer">
              <span class="complaint-date">{{formatDate createdAt}}</span>
              <a href="/complaint/{{_id}}" class="view-details">
                <i class="fas fa-chevron-right"></i>
              </a>
            </div>
          </div>
        {{/each}}
      </div>
    </div>
  {{else}}
    <div class="empty-state">
      <div class="empty-icon">
        <i class="far fa-clipboard"></i>
      </div>
      <h3>No Complaints Yet</h3>
      <p>You haven't submitted any complaints yet</p>
      <a href="/complaint" class="btn btn-primary">
        <i class="fas fa-plus"></i> Submit Your First Complaint
      </a>
    </div>
  {{/if}}
</div>
