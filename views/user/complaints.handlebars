<div class="complaints-container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Complaints</h2>
    <a href="/complaint" class="btn btn-primary">
      <i class="fas fa-plus"></i> New Complaint
    </a>
  </div>

  {{#if complaints.length}}
    <div class="complaints-list">
      {{#each complaints}}
        <div class="complaint-item">
          <div class="complaint-header">
            <span class="complaint-id">Complaint #{{_id}}</span>
            <span class="complaint-date">{{formatDate createdAt}}</span>
          </div>
          
          <div class="complaint-desc">
            <p>{{desc}}</p>
          </div>
          
          <div class="d-flex justify-content-between align-items-center">
            <span class="complaint-status status-{{toLowerCase status}}">
              {{status}}
            </span>
            
            <div class="complaint-actions">
              <a href="/complaint/{{_id}}" class="btn btn-sm view-details-btn">
                <i class="fas fa-eye"></i> View Details
              </a>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-complaints card">
      <div class="card-body">
        <div class="empty-complaints-icon">
          <i class="far fa-folder-open"></i>
        </div>
        <h4>No Complaints Found</h4>
        <p class="text-muted mb-4">You haven't submitted any complaints yet</p>
        <a href="/complaint" class="btn btn-primary">
          Submit Your First Complaint
        </a>
      </div>
    </div>
  {{/if}}
</div>
